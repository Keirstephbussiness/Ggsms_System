{
  "name": "ship-license-management",
  "version": "1.2.0",
  "description": "GGSM SYSTEM - Ship License and Certification Management System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "build": "electron-builder",
    "dist": "electron-builder --publish always"
  },
  "keywords": [
    "electron",
    "ship",
    "license",
    "management",
    "tabulator",
    "ggsm"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "pg": "^8.18.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "build": {
    "appId": "com.yourname.ggsmsystem",
    "productName": "GGSM SYSTEM",
    "asar": true,
    "asarUnpack": [
      "node_modules/pg/**",
      "node_modules/pg-pool/**",
      "node_modules/pg-protocol/**",
      "node_modules/pg-types/**",
      "node_modules/pgpass/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Keirstephbussiness",
        "repo": "Ggsms_System"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!.git/**",
      "!*.md",
      "!*.log"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "images/icon.icns",
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "images/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}