{
  "name": "ship-license-management",
  "version": "1.1.0",
  "description": "GGSM SYSTEM - Ship License and Certification Management System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "build": "electron-builder",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "ship",
    "license",
    "management",
    "tabulator",
    "ggsm"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "pg": "^8.18.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "build": {
    "appId": "com.yourname.ggsmsystem",
    "productName": "GGSM SYSTEM",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "images/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "images/icon.ico"
    }
  }
}
